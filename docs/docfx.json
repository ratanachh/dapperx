{
  "metadata": [
    {
      "src": [
        {
          "src": "../src/DapperX",
          "files": [ "DapperX.csproj" ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "TargetFramework": "net10.0",
        "Configuration": "Release"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/*.md" ]
      },
      {
        "files": [ "articles/**.md", "articles/**/toc.yml", "*.md", "toc.yml" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "template": [
      "default",
      "modern"
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "DapperX",
      "_appTitle": "DapperX",
      "_appFooter": "DapperX is released under the MIT License.",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/ratanachh/dapperx",
        "branch": "main"
      }
    }
  }
}
